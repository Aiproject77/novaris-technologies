function t(key){ return T[LANG][key] || key; }

function setLang(l){
  LANG = l;
  document.getElementById('btn-fr').classList.toggle('active', l==='fr');
  document.getElementById('btn-en').classList.toggle('active', l==='en');
  applyLang();
  renderList();
}

