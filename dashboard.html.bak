function applyExtraLang(){
  Object.keys(EXTRA_I18N).forEach(id=>{
    const el = document.getElementById(id);
    if(el) el.textContent = EXTRA_I18N[id][LANG];
  });
}

// ══════════════════════════════════════════════════════════
// AUTHENTIFICATION (Supabase Auth) — protège les données clients/factures
// ══════════════════════════════════════════════════════════
async function doLogin(){
  const email = document.getElementById('login-email').value.trim();
  const pass = document.getElementById('login-pass').value;
  const err = document.getElementById('login-err');
  err.classList.remove('show');
  const { error } = await sb.auth.signInWithPassword({ email, password: pass });
  if(error){
    err.textContent = LANG==='fr' ? "Identifiants invalides." : "Invalid credentials.";
    err.classList.add('show');
    return;
  }
  boot();
}
async function checkAuth(){
  const { data } = await sb.auth.getSession();
  if(data.session){ boot(); }
  else { document.getElementById('login-wrap').classList.remove('hidden'); document.getElementById('app-root').classList.add('hidden'); }
}
function skipLogin(){
  boot();
}
function boot(){
  document.getElementById('login-wrap').classList.add('hidden');
  document.getElementById('app-root').classList.remove('hidden');
  applyLang();
  loadAll();
  loadSettings();
  loadInvoices();
  loadSurveyConfig();
}

// ══════════════════════════════════════════════════════════
// PARAMÈTRES (taux de taxe, coordonnées de paiement par défaut)
// ══════════════════════════════════════════════════════════
let appSettings = { tax_rate:14.975, default_interac_email:'', default_bank_info:'', company_name:'Novaris Solution Inc.', company_address:'226 rue Rouville, Longueuil, Québec J4K 2W2', company_email:'p_essono@hotmail.com' };
async function loadSettings(){
  const { data } = await sb.from('app_settings').select('*').eq('id',1).maybeSingle();
  if(data) appSettings = data;
  document.getElementById('tax-rate-input').value = appSettings.tax_rate;
}
async function saveTaxRate(v){
  appSettings.tax_rate = parseFloat(v)||0;
  await sb.from('app_settings').update({tax_rate:appSettings.tax_rate}).eq('id',1);
  recalcInvoice(); renderFinMetrics();
}

// ══════════════════════════════════════════════════════════
// FACTURATION
// ══════════════════════════════════════════════════════════
let allInvoices = [];
const INV_PKG = {
  essential:{amount:2500, feats:['feat_chatbot','feat_seo']},
  growth:{amount:3900, feats:['feat_chatbot','feat_seo','feat_automation','feat_booking']},
  full:{amount:6200, feats:['feat_chatbot','feat_seo','feat_automation','feat_booking','feat_portal','feat_payment']},
  custom:{amount:0, feats:[]}
};
const ALL_FEAT_OPTIONS = [
  {key:'feat_chatbot', fr:'Chatbot IA (24/7)', en:'AI Chatbot (24/7)'},
  {key:'feat_quote', fr:'Formulaire de devis instantané', en:'Instant quote form'},
  {key:'feat_portal', fr:'Portail client', en:'Client portal'},
  {key:'feat_payment', fr:'Paiement en ligne', en:'Online payment'},
  {key:'feat_automation', fr:'Automatisation courriels', en:'Email automation'},
  {key:'feat_seo', fr:'SEO local', en:'Local SEO'},
  {key:'feat_booking', fr:'Réservation en ligne', en:'Online booking'},
  {key:'dashboard', fr:'Dashboard analytique', en:'Analytics dashboard'},
  {key:'hosting', fr:'Hébergement inclus (1 an)', en:'Hosting included (1 yr)'},
  {key:'maintenance', fr:'Maintenance mensuelle', en:'Monthly maintenance'}
];
let selectedFeats = new Set();

function genInvoiceNumber(){
  const year = new Date().getFullYear();
  const rand = Math.floor(10000 + Math.random()*89999);
  document.getElementById('inv-number-disp').textContent = `NOV-${year}-${rand}`;
}

function renderFeatChips(){
  const wrap = document.getElementById('inv-feat-chips');
  wrap.innerHTML = ALL_FEAT_OPTIONS.map(f=>`<span class="chip ${selectedFeats.has(f.key)?'sel':''}" onclick="toggleFeat('${f.key}')">${LANG==='fr'?f.fr:f.en}</span>`).join('');
}
function toggleFeat(key){
  if(selectedFeats.has(key)) selectedFeats.delete(key); else selectedFeats.add(key);
  renderFeatChips();
}

function onPkgChange(){
  const pkg = document.getElementById('inv-pkg').value;
  const def = INV_PKG[pkg];
  document.getElementById('inv-amount').value = def.amount || '';
  selectedFeats = new Set(def.feats);
  renderFeatChips();
  recalcInvoice();
}
function onFreqChange(){
  const freq = document.getElementById('inv-freq').value;
  document.getElementById('inv-installments-wrap').style.display = freq==='unique' ? 'none' : 'grid';
  recalcInvoice();
}
function onMethodChange(){
  const m = document.getElementById('inv-method').value;
  const box = document.getElementById('inv-details');
  if(!box.value.trim()){
    if(m==='interac' && appSettings.default_interac_email) box.value = appSettings.default_interac_email;
    if(m==='virement' && appSettings.default_bank_info) box.value = appSettings.default_bank_info;
  }
}

function recalcInvoice(){
  const amount = parseFloat(document.getElementById('inv-amount').value)||0;
  const rate = appSettings.tax_rate||0;
  const tax = +(amount*rate/100).toFixed(2);
  const total = +(amount+tax).toFixed(2);
  document.getElementById('ic-sub-val').textContent = fmtMoney(amount);
  document.getElementById('ic-tax-val').textContent = fmtMoney(tax) + ` (${rate}%)`;
  document.getElementById('ic-total-val').textContent = fmtMoney(total);
  return {amount, tax, total};
}
function fmtMoney(n){
  return (LANG==='fr' ? n.toLocaleString('fr-CA',{minimumFractionDigits:2,maximumFractionDigits:2})+' $' : '$'+n.toLocaleString('en-CA',{minimumFractionDigits:2,maximumFractionDigits:2}));
}

function prefillFromResponse(){
  const idx = document.getElementById('inv-response').value;
  if(idx==='') return;
  const r = allData[idx];
  document.getElementById('inv-name').value = r.contact_name||'';
  document.getElementById('inv-biz').value = r.business_name||'';
  document.getElementById('inv-email').value = r.email||'';
}

function populateResponseDropdown(){
  const sel = document.getElementById('inv-response');
  const cur = sel.value;
  sel.innerHTML = `<option value="" id="il-resp-none">${LANG==='fr'?'— Sélection manuelle —':'— Manual entry —'}</option>` +
    allData.map((r,i)=>`<option value="${i}">${r.contact_name||'—'} · ${r.business_name||'—'}</option>`).join('');
  sel.value = cur;
}

function buildInvoiceObject(){
  const {amount, tax, total} = recalcInvoice();
  const freq = document.getElementById('inv-freq').value;
  const count = freq==='unique' ? 1 : (parseInt(document.getElementById('inv-count').value)||1);
  return {
    invoice_number: document.getElementById('inv-number-disp').textContent,
    response_id: document.getElementById('inv-response').value!=='' ? allData[document.getElementById('inv-response').value].id : null,
    client_name: document.getElementById('inv-name').value,
    client_business: document.getElementById('inv-biz').value,
    client_email: document.getElementById('inv-email').value,
    lang: document.getElementById('inv-lang').value,
    package_key: document.getElementById('inv-pkg').value,
    package_label: document.getElementById('inv-pkg').selectedOptions[0].textContent,
    features: Array.from(selectedFeats).map(k=>{
      const f = ALL_FEAT_OPTIONS.find(x=>x.key===k);
      return f ? (LANG==='fr'?f.fr:f.en) : k;
    }),
    amount, tax_rate: appSettings.tax_rate||0, tax_amount: tax, total_amount: total,
    payment_method: document.getElementById('inv-method').value,
    payment_details: document.getElementById('inv-details').value,
    frequency: freq,
    installments_count: count,
    due_date: document.getElementById('inv-due').value || null,
    notes: document.getElementById('inv-notes').value,
    include_contract: document.getElementById('inv-contract').checked,
    status: 'draft'
  };
}

function invoiceHTMLDoc(inv){
  const isFr = inv.lang==='fr';
  const L = isFr ? {
    facture:'FACTURE', num:'N° de facture', date:'Date', client:'Client', compagnie:'Compagnie',
    details:'DÉTAIL DU FORFAIT', desc:'Description', montant:'Montant', sousTotal:'Sous-total',
    taxes:'Taxes', total:'Total', paiement:'MODALITÉS DE PAIEMENT', methode:'Type de paiement',
    coord:'Coordonnées', freq:'Fréquence', echeance:"Date d'échéance", versements:'Nombre de versements',
    merci: appSettings.invoice_footer_fr || 'Merci de votre confiance.'
  } : {
    facture:'INVOICE', num:'Invoice #', date:'Date', client:'Client', compagnie:'Company',
    details:'PACKAGE DETAILS', desc:'Description', montant:'Amount', sousTotal:'Subtotal',
    taxes:'Tax', total:'Total', paiement:'PAYMENT TERMS', methode:'Payment method',
    coord:'Details', freq:'Frequency', echeance:'Due date', versements:'Number of installments',
    merci: appSettings.invoice_footer_en || 'Thank you for your business.'
  };
  const freqLabels = isFr
    ? {unique:'Paiement unique', mensuel:'Mensuel', hebdomadaire:'Hebdomadaire', annuel:'Annuel'}
    : {unique:'One-time', mensuel:'Monthly', hebdomadaire:'Weekly', annuel:'Yearly'};
  const methLabels = isFr
    ? {virement:'Virement bancaire', interac:'Virement Interac', carte:'Carte de crédit', cheque:'Chèque', autre:'Autre'}
    : {virement:'Bank transfer', interac:'Interac e-Transfer', carte:'Credit card', cheque:'Cheque', autre:'Other'};
  const today = new Date().toLocaleDateString(isFr?'fr-CA':'en-CA',{year:'numeric',month:'long',day:'numeric'});
  return { L, freqLabels, methLabels, today };
}

function generateInvoicePDF(inv){
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({unit:'pt', format:'letter'});
  const { L, freqLabels, methLabels, today } = invoiceHTMLDoc(inv);
  const brand = [108,63,197]; const navy=[15,23,42]; const muted=[100,116,139];
  let y = 50;

  // En-tête
  doc.setFont('helvetica','bold'); doc.setFontSize(16); doc.setTextColor(...navy);
  doc.text('NOVARIS SOLUTION', 50, y);
  doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(...muted);
  y += 16; doc.text('Patrick Essono', 50, y);
  y += 13; doc.text(appSettings.company_address || '226 rue Rouville, Longueuil, Québec J4K 2W2', 50, y);
  y += 13; doc.text(appSettings.company_email || 'p_essono@hotmail.com', 50, y);

  doc.setFont('helvetica','bold'); doc.setFontSize(20); doc.setTextColor(...brand);
  doc.text(L.facture, 545, 55, {align:'right'});
  doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(...muted);
  doc.text(`${L.num}: ${inv.invoice_number}`, 545, 74, {align:'right'});
  doc.text(`${L.date}: ${today}`, 545, 87, {align:'right'});

  y = 130;
  doc.setDrawColor(226,232,240); doc.line(50,y,545,y);
  y += 22;

  // Client
  doc.setFont('helvetica','bold'); doc.setFontSize(10); doc.setTextColor(...navy);
  doc.text(L.client.toUpperCase(), 50, y);
  y += 15; doc.setFont('helvetica','normal'); doc.setFontSize(10.5);
  doc.text(inv.client_name || '—', 50, y);
  y += 14; doc.setFontSize(9.5); doc.setTextColor(...muted);
  doc.text(inv.client_business || '—', 50, y);
  if(inv.client_email){ y += 14; doc.text(inv.client_email, 50, y); }

  y += 30;
  // Détail du forfait
  doc.setFont('helvetica','bold'); doc.setFontSize(10); doc.setTextColor(...navy);
  doc.text(L.details, 50, y);
  y += 10;
  doc.setFillColor(248,250,252); doc.rect(50, y, 495, 22, 'F');
  doc.setFontSize(9); doc.setTextColor(...muted);
  doc.text(L.desc, 58, y+15);
  doc.text(L.montant, 530, y+15, {align:'right'});
  y += 22;
  doc.setFont('helvetica','normal'); doc.setFontSize(10); doc.setTextColor(...navy);
  doc.text(inv.package_label || '—', 58, y+16);
  doc.text(fmtMoney2(inv.amount, inv.lang), 530, y+16, {align:'right'});
  y += 20;
  (inv.features||[]).forEach(f=>{
    doc.setFontSize(9); doc.setTextColor(...muted);
    doc.text('•  '+f, 66, y+10);
    y += 16;
  });
  y += 10;
  doc.setDrawColor(226,232,240); doc.line(50,y,545,y);
  y += 6;

  // Totaux
  const totalsX = 380;
  y += 16; doc.setFontSize(9.5); doc.setTextColor(...muted);
  doc.text(L.sousTotal, totalsX, y); doc.text(fmtMoney2(inv.amount, inv.lang), 545, y, {align:'right'});
  y += 16; doc.text(`${L.taxes} (${inv.tax_rate}%)`, totalsX, y); doc.text(fmtMoney2(inv.tax_amount, inv.lang), 545, y, {align:'right'});
  y += 18; doc.setFont('helvetica','bold'); doc.setFontSize(12); doc.setTextColor(...brand);
  doc.text(L.total, totalsX, y); doc.text(fmtMoney2(inv.total_amount, inv.lang), 545, y, {align:'right'});

  y += 34;
  doc.setDrawColor(226,232,240); doc.line(50,y,545,y);
  y += 22;

  // Paiement
  doc.setFont('helvetica','bold'); doc.setFontSize(10); doc.setTextColor(...navy);
  doc.text(L.paiement, 50, y);
  y += 16; doc.setFont('helvetica','normal'); doc.setFontSize(9.5); doc.setTextColor(...muted);
  doc.text(`${L.methode}: `, 50, y); doc.setTextColor(...navy); doc.text(methLabels[inv.payment_method]||inv.payment_method, 140, y);
  y += 15; doc.setTextColor(...muted); doc.text(`${L.freq}: `, 50, y); doc.setTextColor(...navy); doc.text(freqLabels[inv.frequency]||inv.frequency, 140, y);
  if(inv.frequency !== 'unique'){
    y += 15; doc.setTextColor(...muted); doc.text(`${L.versements}: `, 50, y); doc.setTextColor(...navy); doc.text(String(inv.installments_count), 140, y);
  }
  if(inv.due_date){
    y += 15; doc.setTextColor(...muted); doc.text(`${L.echeance}: `, 50, y); doc.setTextColor(...navy); doc.text(inv.due_date, 140, y);
  }
  if(inv.payment_details){
    y += 20;
    doc.setTextColor(...muted); doc.text(`${L.coord}:`, 50, y);
    y += 14;
    const lines = doc.splitTextToSize(inv.payment_details, 495);
    doc.setTextColor(...navy);
    doc.text(lines, 50, y);
    y += lines.length*13;
  }

  // Clauses contractuelles + signatures (si le document est généré comme contrat)
  if(inv.include_contract){
    const CLAUSES = inv.lang==='fr' ? {
      title:'CONDITIONS CONTRACTUELLES',
      items:[
        'Portée du mandat — Ce document confirme le mandat décrit dans le détail du forfait ci-dessus, incluant toutes les options énumérées.',
        'Propriété — Une fois le paiement complété, le client détient la pleine propriété du code source et du nom de domaine livrés.',
        'Révisions — Une (1) ronde de révisions est incluse après la livraison initiale.',
        'Support — Un support de 30 jours suivant le lancement est inclus.',
        'Modalités de paiement — Selon les modalités décrites à la section « Modalités de paiement » ci-dessus.'
      ],
      accept:'En signant ci-dessous, les deux parties acceptent les termes du présent contrat.',
      clientSig:'Signature du client', novarisSig:'Novaris Solution Inc.', date:'Date'
    } : {
      title:'CONTRACT TERMS',
      items:[
        'Scope of work — This document confirms the mandate described in the package details above, including all listed options.',
        'Ownership — Once payment is completed, the client holds full ownership of the delivered source code and domain name.',
        'Revisions — One (1) round of revisions is included after initial delivery.',
        'Support — 30 days of post-launch support is included.',
        'Payment terms — As described in the "Payment Terms" section above.'
      ],
      accept:'By signing below, both parties accept the terms of this contract.',
      clientSig:'Client signature', novarisSig:'Novaris Solution Inc.', date:'Date'
    };
    if(y > 620){ doc.addPage(); y = 50; } else { y += 30; }
    doc.setDrawColor(226,232,240); doc.line(50,y,545,y);
    y += 22;
    doc.setFont('helvetica','bold'); doc.setFontSize(10); doc.setTextColor(...navy);
    doc.text(CLAUSES.title, 50, y);
    y += 16;
    CLAUSES.items.forEach((item,idx)=>{
      const lines = doc.splitTextToSize(`${idx+1}. ${item}`, 495);
      if(y + lines.length*13 > 730){ doc.addPage(); y = 50; }
      doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(...muted);
      doc.text(lines, 50, y);
      y += lines.length*13 + 5;
    });
    y += 10;
    if(y > 700){ doc.addPage(); y = 50; }
    doc.setFont('helvetica','italic'); doc.setFontSize(9); doc.setTextColor(...navy);
    doc.text(CLAUSES.accept, 50, y);
    y += 50;
    if(y > 700){ doc.addPage(); y = 50; }
    doc.setDrawColor(148,163,184);
    doc.line(50, y, 260, y); doc.line(335, y, 545, y);
    y += 14;
    doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(...muted);
    doc.text(CLAUSES.clientSig, 50, y); doc.text(CLAUSES.novarisSig, 335, y);
    y += 26;
    doc.line(50, y, 260, y); doc.line(335, y, 545, y);
    y += 14;
    doc.text(CLAUSES.date, 50, y); doc.text(CLAUSES.date, 335, y);
    y += 30;
  } else {
    y += 30;
  }

  doc.setFont('helvetica','italic'); doc.setFontSize(9.5); doc.setTextColor(...muted);
  doc.text(inv.lang==='fr' ? (appSettings.invoice_footer_fr||'Merci de votre confiance.') : (appSettings.invoice_footer_en||'Thank you for your business.'), 50, y);

  return doc;
}
function fmtMoney2(n, lang){
  n = Number(n)||0;
  return (lang==='fr' ? n.toLocaleString('fr-CA',{minimumFractionDigits:2,maximumFractionDigits:2})+' $' : '$'+n.toLocaleString('en-CA',{minimumFractionDigits:2,maximumFractionDigits:2}));
}

function previewInvoicePDF(){
  const inv = buildInvoiceObject();
  const doc = generateInvoicePDF(inv);
  const blobUrl = doc.output('bloburl');
  document.getElementById('inv-pdf-frame').src = blobUrl;
}
function downloadInvoicePDF(){
  const inv = buildInvoiceObject();
  const doc = generateInvoicePDF(inv);
  doc.save(inv.invoice_number+'.pdf');
}

// ── MESSAGE COURRIEL (texte brut, copier-coller manuel — aucune configuration requise) ──
function buildEmailText(inv){
  const isFr = inv.lang==='fr';
  const docWord = inv.include_contract ? (isFr?'facture-contrat':'invoice-contract') : (isFr?'facture':'invoice');
  const subject = isFr
    ? `Votre ${docWord} Novaris Solution — ${inv.invoice_number}`
    : `Your Novaris Solution ${docWord} — ${inv.invoice_number}`;
  const contractNote = inv.include_contract
    ? (isFr
        ? "Ce document inclut le détail du forfait ainsi que les conditions contractuelles. Merci d'y apposer votre signature et de nous la retourner.\n\n"
        : "This document includes the package details and the contract terms. Please sign it and return it to us.\n\n")
    : '';
  const body = isFr
    ? `Bonjour ${inv.client_name||''},\n\nVeuillez trouver ci-joint votre ${docWord} ${inv.invoice_number} pour ${inv.client_business||'votre entreprise'}, d'un montant total de ${fmtMoney2(inv.total_amount,'fr')}.\n\n${contractNote}Merci de votre confiance,\nPatrick Essono\nNovaris Solution Inc.\n${appSettings.company_email||'p_essono@hotmail.com'}`
    : `Hi ${inv.client_name||''},\n\nPlease find attached your ${docWord} ${inv.invoice_number} for ${inv.client_business||'your business'}, totaling ${fmtMoney2(inv.total_amount,'en')}.\n\n${contractNote}Thank you for your business,\nPatrick Essono\nNovaris Solution Inc.\n${appSettings.company_email||'p_essono@hotmail.com'}`;
  return { subject, body };
}
function generateEmailMessage(){
  const inv = buildInvoiceObject();
  if(!inv.client_name && !inv.client_business){
    showToast(LANG==='fr' ? "Ajoute au moins le nom du client avant de générer le message." : "Add at least the client's name before generating the message.");
  }
  const { subject, body } = buildEmailText(inv);
  const subjLabel = LANG==='fr' ? 'Objet' : 'Subject';
  document.getElementById('inv-email-text').value = `${subjLabel}: ${subject}\n\n${body}`;
}
function copyEmailMessage(){
  const el = document.getElementById('inv-email-text');
  if(!el.value.trim()){ generateEmailMessage(); }
  navigator.clipboard.writeText(el.value).then(()=>{
    showToast(LANG==='fr' ? 'Message copié — colle-le dans ton courriel.' : 'Message copied — paste it into your email.');
  });
}

async function saveAndSendInvoice(){
  const inv = buildInvoiceObject();
  if(!inv.client_email){
    showToast(LANG==='fr' ? 'Ajoutez un courriel client pour envoyer la facture.' : 'Add a client email to send the invoice.');
    return;
  }
  inv.status = 'sent';
  const { data, error } = await sb.from('invoices').insert([inv]).select().single();
  if(error){ showToast('Erreur: '+error.message); return; }

  // Génère les versements si récurrent
  if(inv.frequency !== 'unique' && inv.installments_count > 1){
    const start = document.getElementById('inv-start').value ? new Date(document.getElementById('inv-start').value) : new Date();
    const installments = [];
    const perAmount = +(inv.total_amount / inv.installments_count).toFixed(2);
    for(let i=0;i<inv.installments_count;i++){
      const d = new Date(start);
      if(inv.frequency==='mensuel') d.setMonth(d.getMonth()+i);
      else if(inv.frequency==='hebdomadaire') d.setDate(d.getDate()+7*i);
      else if(inv.frequency==='annuel') d.setFullYear(d.getFullYear()+i);
      installments.push({invoice_id:data.id, seq:i+1, due_date:d.toISOString().slice(0,10), amount:perAmount, paid:false});
    }
    await sb.from('invoice_installments').insert(installments);
  }

  const doc = generateInvoicePDF(inv);
  const pdfBase64 = doc.output('datauristring').split(',')[1];
  const { L } = invoiceHTMLDoc(inv);
  const subject = inv.lang==='fr' ? `Votre facture Novaris Solution — ${inv.invoice_number}` : `Your Novaris Solution invoice — ${inv.invoice_number}`;
  const html = inv.lang==='fr'
    ? `<p>Bonjour ${inv.client_name||''},</p><p>Veuillez trouver ci-joint votre facture <strong>${inv.invoice_number}</strong> pour ${inv.client_business||'votre entreprise'}, d'un montant total de ${fmtMoney2(inv.total_amount,'fr')}.</p><p>Merci de votre confiance,<br>Patrick Essono — Novaris Solution Inc.</p>`
    : `<p>Hi ${inv.client_name||''},</p><p>Please find attached your invoice <strong>${inv.invoice_number}</strong> for ${inv.client_business||'your business'}, totaling ${fmtMoney2(inv.total_amount,'en')}.</p><p>Thank you for your business,<br>Patrick Essono — Novaris Solution Inc.</p>`;

  try{
    const resp = await fetch(SEND_INVOICE_URL, {
      method:'POST',
      headers:{'Content-Type':'application/json', 'Authorization':'Bearer '+SUPABASE_ANON_KEY},
      body: JSON.stringify({ to: inv.client_email, subject, html, pdf_base64: pdfBase64, filename: inv.invoice_number+'.pdf' })
    });
    const result = await resp.json();
    if(!resp.ok) throw new Error(result.error ? JSON.stringify(result.error) : 'Erreur inconnue');
    await sb.from('invoices').update({sent_at:new Date().toISOString()}).eq('id',data.id);
    showToast(LANG==='fr' ? `Facture ${inv.invoice_number} envoyée à ${inv.client_email}` : `Invoice ${inv.invoice_number} sent to ${inv.client_email}`);
  }catch(e){
    showToast((LANG==='fr' ? 'Facture enregistrée, mais l\'envoi a échoué : ' : 'Invoice saved, but sending failed: ') + e.message);
  }
  loadInvoices();
}

async function loadInvoices(){
  const { data } = await sb.from('invoices').select('*, invoice_installments(*)').order('created_at',{ascending:false});
  allInvoices = data || [];
  renderFinMetrics();
  renderInvoicesList();
}

function renderFinMetrics(){
  if(!allInvoices) return;
  const active = allInvoices.filter(i=>i.status!=='cancelled');
  const concluded = active.reduce((s,i)=>s+(Number(i.total_amount)||0),0);
  let paid = 0, due = 0;
  active.forEach(i=>{
    const installs = i.invoice_installments||[];
    if(installs.length){
      installs.forEach(x=>{ if(x.paid) paid += Number(x.amount)||0; else due += Number(x.amount)||0; });
    } else {
      if(i.status==='paid') paid += Number(i.total_amount)||0; else due += Number(i.total_amount)||0;
    }
  });
  const taxRate = appSettings.tax_rate||0;
  const taxOnCollected = +(paid*taxRate/100).toFixed(2);
  const net = +(paid - taxOnCollected).toFixed(2);
  document.getElementById('fm-1').textContent = fmtMoney(concluded);
  document.getElementById('fm-2').textContent = fmtMoney(paid);
  document.getElementById('fm-3').textContent = fmtMoney(due);
  document.getElementById('fm-4').textContent = fmtMoney(net);
  document.getElementById('fm-tax-val').textContent = fmtMoney(taxOnCollected);
}

function invStatusBadge(s){
  const map = {draft:'b-draft',sent:'b-sent',paid:'b-paid',overdue:'b-overdue',cancelled:'b-cancelled'};
  const labels = LANG==='fr'
    ? {draft:'Brouillon',sent:'Envoyée',paid:'Payée',overdue:'En retard',cancelled:'Annulée'}
    : {draft:'Draft',sent:'Sent',paid:'Paid',overdue:'Overdue',cancelled:'Cancelled'};
  return `<span class="badge ${map[s]||'b-draft'}">${labels[s]||s}</span>`;
}

function renderInvoicesList(){
  const list = document.getElementById('invoices-list');
  if(!allInvoices.length){ list.innerHTML = `<div class="empty-state" id="inv-empty">${LANG==='fr'?'Aucune facture pour le moment.':'No invoices yet.'}</div>`; return; }
  list.innerHTML = allInvoices.map(i=>`
    <div class="inv-row">
      <div class="num">${i.invoice_number}</div>
      <div><div class="biz">${i.client_name||'—'} · ${i.client_business||'—'}</div><div class="sub">${i.package_label||''} · ${i.frequency}</div></div>
      <div class="amt">${fmtMoney(Number(i.total_amount)||0)}</div>
      ${invStatusBadge(i.status)}
      <div class="sv-field-actions">
        <button onclick='markInvoicePaid("${i.id}")' title="${LANG==='fr'?'Marquer payée':'Mark paid'}">✓</button>
        <button onclick='deleteInvoice("${i.id}")' title="${LANG==='fr'?'Supprimer':'Delete'}">✕</button>
      </div>
    </div>`).join('');
}
async function markInvoicePaid(id){
  await sb.from('invoices').update({status:'paid', paid_at:new Date().toISOString()}).eq('id',id);
  await sb.from('invoice_installments').update({paid:true, paid_at:new Date().toISOString()}).eq('invoice_id',id);
  loadInvoices();
}
async function deleteInvoice(id){
  if(!confirm(LANG==='fr'?'Supprimer cette facture ?':'Delete this invoice?')) return;
  await sb.from('invoices').delete().eq('id',id);
  loadInvoices();
}

// ══════════════════════════════════════════════════════════
// CONSTRUCTEUR DE SURVEY
// ══════════════════════════════════════════════════════════
let surveyFields = [];
let editingFieldId = null;

async function loadSurveyConfig(){
  const { data } = await sb.from('survey_config').select('*').order('step_number').order('sort_order');
  surveyFields = data || [];
  renderSurveyBuilder();
  if(typeof renderList === 'function' && allData.length) renderList();
}

function renderSurveyBuilder(){
  const wrap = document.getElementById('sv-steps-list');
  if(!wrap) return;
  const steps = {};
  surveyFields.forEach(f=>{ (steps[f.step_number] = steps[f.step_number]||[]).push(f); });
  const stepNums = Object.keys(steps).map(Number).sort((a,b)=>a-b);
  wrap.innerHTML = stepNums.map(sn=>{
    const fields = steps[sn];
    return `<div class="sv-step-card">
      <div class="sv-step-head"><span>${LANG==='fr'?'Étape':'Step'} ${sn} — ${fields[0].question_fr}</span>
        <button class="btn btn-outline btn-sm" onclick="addFieldToStep(${sn})">+ ${LANG==='fr'?'Champ':'Field'}</button>
      </div>
      ${fields.map(f=>`
        <div class="sv-field-row ${!f.active?'sv-inactive':''}">
          <div class="sv-field-info">${LANG==='fr'?f.question_fr:f.question_en} <span class="k">${f.field_key} · ${f.field_type}</span></div>
          <div class="sv-field-actions">
            <button onclick="editField('${f.id}')" title="${LANG==='fr'?'Modifier':'Edit'}">✎</button>
            <button onclick="deleteField('${f.id}')" title="${LANG==='fr'?'Supprimer':'Delete'}">✕</button>
          </div>
        </div>`).join('')}
    </div>`;
  }).join('') || `<div class="empty-state">${LANG==='fr'?'Aucune question configurée.':'No questions configured yet.'}</div>`;
}

function blankField(stepNumber){
  return { id:null, step_number:stepNumber, sort_order:1, field_key:'', field_type:'text',
    question_fr:'', question_en:'', subtitle_fr:'', subtitle_en:'', placeholder_fr:'', placeholder_en:'',
    options:[], min_val:0, max_val:100, step_val:1, prefix:'', suffix:'', required:false, active:true };
}
function addNewStep(){
  const maxStep = surveyFields.length ? Math.max(...surveyFields.map(f=>f.step_number)) : 0;
  openFieldEditor(blankField(maxStep+1));
}
function addFieldToStep(stepNumber){
  const inStep = surveyFields.filter(f=>f.step_number===stepNumber);
  const maxSort = inStep.length ? Math.max(...inStep.map(f=>f.sort_order)) : 0;
  const f = blankField(stepNumber); f.sort_order = maxSort+1;
  openFieldEditor(f);
}
function editField(id){
  const f = surveyFields.find(x=>x.id===id);
  if(f) openFieldEditor(JSON.parse(JSON.stringify(f)));
}
async function deleteField(id){
  if(!confirm(LANG==='fr'?'Supprimer cette question ?':'Delete this question?')) return;
  await sb.from('survey_config').delete().eq('id',id);
  loadSurveyConfig();
}

function openFieldEditor(f){
  editingFieldId = f.id;
  const needsOptions = ['radio','checkbox','select','importance'].includes(f.field_type);
  const needsRange = f.field_type==='range';
  const editor = document.getElementById('sv-editor');
  editor.innerHTML = `
    <div class="card-title" style="margin-bottom:12px">${f.id ? (LANG==='fr'?'Modifier la question':'Edit question') : (LANG==='fr'?'Nouvelle question':'New question')}</div>
    <div class="pf">
      <label>${LANG==='fr'?'Clé technique (unique, sans espace)':'Field key (unique, no spaces)'}</label>
      <input type="text" id="sf-key" value="${f.field_key}" ${f.id?'disabled':''} placeholder="ex. feat_livechat">
      <div class="inv-form-row">
        <div><label>${LANG==='fr'?'Étape #':'Step #'}</label><input type="number" id="sf-step" value="${f.step_number}"></div>
        <div><label>${LANG==='fr'?"Ordre dans l'étape":'Order in step'}</label><input type="number" id="sf-order" value="${f.sort_order}"></div>
      </div>
      <label>${LANG==='fr'?'Type de champ':'Field type'}</label>
      <select id="sf-type" onchange="onFieldTypeChange(this.value)">
        ${['text','textarea','radio','checkbox','select','range','importance'].map(t=>`<option value="${t}" ${f.field_type===t?'selected':''}>${t}</option>`).join('')}
      </select>
      <label>${LANG==='fr'?'Question (FR)':'Question (FR)'}</label><input type="text" id="sf-qfr" value="${(f.question_fr||'').replace(/"/g,'&quot;')}">
      <label>Question (EN)</label><input type="text" id="sf-qen" value="${(f.question_en||'').replace(/"/g,'&quot;')}">
      <label>${LANG==='fr'?'Sous-titre étape (FR, optionnel)':'Step subtitle (FR, optional)'}</label><input type="text" id="sf-subfr" value="${(f.subtitle_fr||'').replace(/"/g,'&quot;')}">
      <label>${LANG==='fr'?'Sous-titre étape (EN, optionnel)':'Step subtitle (EN, optional)'}</label><input type="text" id="sf-suben" value="${(f.subtitle_en||'').replace(/"/g,'&quot;')}">
      <div id="sf-options-wrap" style="display:${needsOptions?'block':'none'}">
        <label>${LANG==='fr'?'Options (valeur / FR / EN)':'Options (value / FR / EN)'}</label>
        <div id="sf-options-list"></div>
        <button class="btn btn-outline btn-sm" onclick="addOptionRow()">+ ${LANG==='fr'?'Option':'Option'}</button>
      </div>
      <div id="sf-range-wrap" style="display:${needsRange?'block':'none'}">
        <div class="inv-form-row">
          <div><label>Min</label><input type="number" id="sf-min" value="${f.min_val??0}"></div>
          <div><label>Max</label><input type="number" id="sf-max" value="${f.max_val??100}"></div>
        </div>
        <div class="inv-form-row">
          <div><label>${LANG==='fr'?'Pas':'Step'}</label><input type="number" id="sf-step-val" value="${f.step_val??1}"></div>
          <div><label>${LANG==='fr'?'Préfixe/Suffixe':'Prefix/Suffix'}</label><input type="text" id="sf-suffix" value="${f.suffix||''}" placeholder="$, /mois..."></div>
        </div>
      </div>
      <div class="toggle-row"><input type="checkbox" id="sf-required" ${f.required?'checked':''}><label>${LANG==='fr'?'Obligatoire':'Required'}</label></div>
      <div class="toggle-row"><input type="checkbox" id="sf-active" ${f.active?'checked':''}><label>${LANG==='fr'?'Actif (visible sur le survey public)':'Active (visible on public survey)'}</label></div>
      <div style="display:flex;gap:8px;margin-top:14px">
        <button class="btn btn-brand" style="flex:1;justify-content:center" onclick="saveField()">${LANG==='fr'?'Enregistrer':'Save'}</button>
        <button class="btn btn-outline" onclick="renderSurveyBuilder();document.getElementById('sv-editor').innerHTML='<div class=\\'empty-state\\' id=\\'sv-editor-empty\\'>'+(LANG==='fr'?'Sélectionnez une question à gauche pour la modifier, ou créez-en une nouvelle.':'Select a question on the left to edit it, or create a new one.')+'</div>'">${LANG==='fr'?'Annuler':'Cancel'}</button>
      </div>
    </div>`;
  window._optRows = (f.options && f.options.length) ? JSON.parse(JSON.stringify(f.options)) : [];
  renderOptionRows();
}
function onFieldTypeChange(t){
  const needsOptions = ['radio','checkbox','select','importance'].includes(t);
  document.getElementById('sf-options-wrap').style.display = needsOptions?'block':'none';
  document.getElementById('sf-range-wrap').style.display = t==='range'?'block':'none';
}
function renderOptionRows(){
  const el = document.getElementById('sf-options-list');
  if(!el) return;
  el.innerHTML = (window._optRows||[]).map((o,i)=>`
    <div class="opt-editor-row">
      <input type="text" placeholder="valeur" value="${(o.value||'').replace(/"/g,'&quot;')}" onchange="window._optRows[${i}].value=this.value">
      <input type="text" placeholder="FR" value="${(o.label_fr||'').replace(/"/g,'&quot;')}" onchange="window._optRows[${i}].label_fr=this.value">
      <input type="text" placeholder="EN" value="${(o.label_en||'').replace(/"/g,'&quot;')}" onchange="window._optRows[${i}].label_en=this.value">
      <button onclick="removeOptionRow(${i})" style="background:none;border:1px solid var(--border);border-radius:6px;cursor:pointer">✕</button>
    </div>`).join('');
}
function addOptionRow(){ window._optRows = window._optRows||[]; window._optRows.push({value:'',label_fr:'',label_en:''}); renderOptionRows(); }
function removeOptionRow(i){ window._optRows.splice(i,1); renderOptionRows(); }

async function saveField(){
  const payload = {
    field_key: document.getElementById('sf-key').value.trim(),
    step_number: parseInt(document.getElementById('sf-step').value)||1,
    sort_order: parseInt(document.getElementById('sf-order').value)||1,
    field_type: document.getElementById('sf-type').value,
    question_fr: document.getElementById('sf-qfr').value,
    question_en: document.getElementById('sf-qen').value,
    subtitle_fr: document.getElementById('sf-subfr').value,
    subtitle_en: document.getElementById('sf-suben').value,
    options: window._optRows||[],
    min_val: parseFloat(document.getElementById('sf-min')?.value)||0,
    max_val: parseFloat(document.getElementById('sf-max')?.value)||100,
    step_val: parseFloat(document.getElementById('sf-step-val')?.value)||1,
    suffix: document.getElementById('sf-suffix')?.value||'',
    required: document.getElementById('sf-required').checked,
    active: document.getElementById('sf-active').checked
  };
  if(!payload.field_key){ showToast(LANG==='fr'?'La clé technique est requise.':'Field key is required.'); return; }
  if(editingFieldId){
    await sb.from('survey_config').update(payload).eq('id',editingFieldId);
  } else {
    await sb.from('survey_config').insert([payload]);
  }
  showToast(LANG==='fr'?'Question enregistrée.':'Question saved.');
  loadSurveyConfig();
}

// ══════════════════════════════════════════════════════════
// LECTEUR GÉNÉRIQUE DE RÉPONSES (couvre les champs standards + personnalisés)
// ══════════════════════════════════════════════════════════
function getFieldValue(r, key){
  if(r.responses_data && r.responses_data[key] !== undefined && r.responses_data[key] !== '') return r.responses_data[key];
  if(r[key] !== undefined && r[key] !== null && r[key] !== '') return r[key];
  return null;
}
function renderAllAnswers(r){
  if(!surveyFields.length) return `<span style="color:var(--muted);font-size:.78rem">—</span>`;
  const steps = {};
  surveyFields.forEach(f=>{ (steps[f.step_number]=steps[f.step_number]||[]).push(f); });
  const stepNums = Object.keys(steps).map(Number).sort((a,b)=>a-b);
  return stepNums.map(sn=>{
    const rows = steps[sn].map(f=>{
      const v = getFieldValue(r, f.field_key);
      if(v===null) return '';
      return `<div class="det-item"><div class="dl">${LANG==='fr'?f.question_fr:f.question_en}</div><div class="dv">${v}</div></div>`;
    }).filter(Boolean).join('');
    return rows ? `<div class="det-section"><div class="det-label">${LANG==='fr'?'Étape':'Step'} ${sn}</div><div class="det-grid">${rows}</div></div>` : '';
  }).join('');
}

// Init
checkAuth();
document.getElementById('inv-due').valueAsDate = new Date();
genInvoiceNumber();
onPkgChange();
</script>
</body>
</html>
