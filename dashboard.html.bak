// ── TRADUCTION MYMEMORY (GRATUIT) ──
const transCache = {};
async function translateFree(text){
  if(!text || !text.trim()) return text;
  const key = text.substring(0,40);
  if(transCache[key]) return transCache[key];
  try {
    const url = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(text.substring(0,500))}&langpair=en|fr&de=contact@novaris-solution.com`;
    const r = await fetch(url);
    const d = await r.json();
    const result = d?.responseData?.translatedText || text;
    transCache[key] = result;
    return result;
  } catch(e) { return text; }
}

async function showTranslation(r, idx){
  const el = document.getElementById('tbox-content-'+idx);
  if(!el) return;
  el.innerHTML = `<div class="tloading">${t('translating')}</div>`;
  const fields = [
    { key:'biggest_challenge', label: LANG==='fr'?'Défi principal':'Main challenge' },
    { key:'primary_goal', label: LANG==='fr'?'Objectif':'Goal' },
    { key:'lead_source', label: LANG==='fr'?'Sources de leads':'Lead sources' },
    { key:'manual_task', label: LANG==='fr'?'Tâches manuelles':'Manual tasks' },
    { key:'additional_notes', label: LANG==='fr'?'Notes':'Notes' }
  ].filter(f => r[f.key] && r[f.key].trim());
  
  const results = await Promise.all(fields.map(async f => {
    const translated = await translateFree(r[f.key]);
    return { label: f.label, original: r[f.key], translated };
  }));
  
  el.innerHTML = results.map(res => `
    <div class="tbox-section">
      <div class="ts-label">${res.label}</div>
      <div class="ts-val">${LANG==='fr' ? res.translated : res.original}</div>
    </div>`).join('') || `<span style="color:var(--muted);font-size:.78rem">${LANG==='fr'?'Aucun texte libre à traduire':'No free text to translate'}</span>`;
}

// ── DONNÉES ──
let allData = [];
const BUDGET_VAL = {'Under $2,000':1500,'$2,000 – $3,500':2750,'$3,500 – $6,000':4750,'$6,000 – $10,000':8000,'Monthly payments preferred':3000};

async function loadAll(){
  const { data } = await sb.from('survey_responses').select('*').order('submitted_at',{ascending:false});
  allData = data || [];
  updateMetrics();
  renderList();
  if(typeof populateResponseDropdown === 'function') populateResponseDropdown();
}

// ── REALTIME ──
sb.channel('novaris_survey')
  .on('postgres_changes',{ event:'INSERT', schema:'public', table:'survey_responses' }, p => {
    allData.unshift(p.new);
    updateMetrics();
    renderList();
    showToast(`${t('toast_new')} ${p.new.contact_name||'—'} (${p.new.business_name||''})`);
    document.getElementById('nb-new').textContent = allData.filter(r=>r.status==='new').length;
    if(typeof populateResponseDropdown === 'function') populateResponseDropdown();
  })
  .subscribe(s => {
    const b = document.getElementById('live-badge');
    b.textContent = s==='SUBSCRIBED' ? T[LANG].live : T[LANG].connecting;
    b.className = 'status-pill ' + (s==='SUBSCRIBED'?'sp-live':'sp-warn');
  });

function showToast(msg, dur=7000){
  const t = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), dur);
}

function updateMetrics(){
  document.getElementById('m-total').textContent = allData.length;
  document.getElementById('count-badge').textContent = allData.length;
  const news = allData.filter(r=>r.status==='new').length;
  document.getElementById('m-new').textContent = news;
  document.getElementById('nb-new').textContent = news;
  const total = allData.reduce((s,r)=>s+(BUDGET_VAL[r.budget]||2500),0);
  document.getElementById('m-pipe').textContent = '$'+total.toLocaleString();
  const bm={};
  allData.forEach(r=>{ if(r.budget) bm[r.budget]=(bm[r.budget]||0)+1; });
  const top = Object.entries(bm).sort((a,b)=>b[1]-a[1])[0];
  document.getElementById('m-budget').textContent = top ? top[0].split(' ')[0] : '—';
}

function getScore(r){
  let s=0;
  if(r.feat_chatbot==='Must have')s+=2;
  if(r.feat_portal==='Must have')s+=2;
  if(r.feat_payment==='Must have')s+=2;
  if(r.feat_automation==='Must have')s+=1;
  if(['$3,500 – $6,000','$6,000 – $10,000'].includes(r.budget))s+=2;
  if(['ASAP (within 2 weeks)','Within 1 month'].includes(r.timeline))s+=1;
  return Math.min(s,10);
}

function getStatusBadge(s){
  const L = T[LANG];
  const map = {new:`b-new`,reviewed:`b-seen`,proposal_sent:`b-proposal`,won:`b-won`};
  const labels = {new:L.new, reviewed:L.seen, proposal_sent:L.proposal, won:L.won};
  return `<span class="badge ${map[s]||'b-seen'}">${labels[s]||s}</span>`;
}

function renderList(){
  const L = T[LANG];
  const filter = document.getElementById('filter-status').value;
  let data = allData;
  if(filter) data = data.filter(r=>r.status===filter||(!r.status&&filter==='new'));
  const list = document.getElementById('resp-list');
  if(!data.length){ list.innerHTML=`<div class="empty-state">${L.empty}</div>`; return; }

  list.innerHTML = data.map((r,i)=>{
    const score = getScore(r);
    const sc = score>=7?'var(--green)':score>=4?'var(--amber)':'var(--red)';
    const sLabel = score>=7?L.score_hi:score>=4?L.score_mid:L.score_lo;
    const scBadge = score>=7?'b-score-hi':score>=4?'b-score-mid':'b-score-lo';
    const date = r.submitted_at?new Date(r.submitted_at).toLocaleString(LANG==='fr'?'fr-CA':'en-CA',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}):'—';
    const initials = (r.contact_name||'?').split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
    const feats = ['chatbot','quote','portal','payment','automation','seo','booking','live_chat'].map(f=>{
      const v = r['feat_'+f]; if(!v||v==='') return '';
      const cls = v==='Must have'?'ft-must':v==='Nice to have'?'ft-nice':'ft-no';
      const label = v==='Must have'?L.ft_must:v==='Nice to have'?L.ft_nice:L.ft_no;
      return `<span class="ft ${cls}">${L.feat_names['feat_'+f]}: ${label}</span>`;
    }).join('');

    return `<div class="rrow" id="rrow-${i}">
      <div class="rhead" onclick="toggleRow(${i})">
        <div class="ravatar">${initials}</div>
        <div>
          <div class="rname">${r.contact_name||'—'} <span style="font-weight:400;color:var(--muted)">· ${r.business_name||'—'}</span></div>
          <div class="rbiz">${r.city||''} · ${r.budget||'Budget non précisé'} · ${r.revenue_target_display||''}</div>
        </div>
        <div class="rmeta">
          <span class="badge ${scBadge}">${score}/10</span>
          ${getStatusBadge(r.status||'new')}
          <span class="rdate">${date}</span>
        </div>
      </div>
      <div class="rbody">
        <div class="tbox">
          <div class="tbox-head">
            <span class="tbox-badge">MyMemory</span>
            <span class="tbox-label">${L.translated}</span>
            <span class="tbox-free">${L.free}</span>
          </div>
          <div class="tbox-content" id="tbox-content-${i}">
            <button class="btn btn-outline btn-sm" onclick="showTranslation(allData[${i}],${i})">${L.translate_btn}</button>
          </div>
        </div>
        <div class="det-section">
          <div class="det-label" style="margin-bottom:5px">${L.score_label} — ${sLabel}</div>
          <div class="score-row"><div class="score-track"><div class="score-fill" style="width:${score*10}%;background:${sc}"></div></div><span class="score-label" style="color:${sc}">${score}/10</span></div>
        </div>
        <div class="det-section">
          <div class="det-label">${L.det_features.toUpperCase()}</div>
          <div class="feat-wrap">${feats||`<span style="color:var(--muted);font-size:.73rem">—</span>`}</div>
        </div>
        <div class="det-section">
          <div class="det-label">${LANG==='fr'?'TOUTES LES RÉPONSES DU SURVEY':'ALL SURVEY ANSWERS'}</div>
          ${renderAllAnswers(r)}
        </div>
        <div class="act-row">
          <button class="btn btn-brand btn-sm" onclick="markSeen('${r.id}',${i})">${L.mark_seen}</button>
          <button class="btn btn-outline btn-sm" onclick="prefill(${i})">${L.create_quote}</button>
          <select class="status-sel" onchange="updateStatus('${r.id}',this.value,${i});this.value=''">
            <option value="">${L.change_status}</option>
            <option value="new">${L.new}</option>
            <option value="proposal_sent">${L.proposal}</option>
            <option value="follow_up">Follow-up</option>
            <option value="won">${L.won}</option>
          </select>
          <button class="btn btn-danger btn-sm" style="margin-left:auto" onclick="deleteR('${r.id}',${i})">${L.delete}</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function toggleRow(i){ document.getElementById('rrow-'+i).classList.toggle('expanded'); }

async function markSeen(id,i){
  await sb.from('survey_responses').update({status:'reviewed'}).eq('id',id);
  allData[allData.findIndex(r=>r.id===id)].status='reviewed';
  updateMetrics(); renderList();
}
async function updateStatus(id,status,i){
  if(!status) return;
  await sb.from('survey_responses').update({status}).eq('id',id);
  allData[allData.findIndex(r=>r.id===id)].status=status;
  updateMetrics(); renderList();
  if(status!=='new') renderPipeline();
}
async function deleteR(id,i){
  if(!confirm(LANG==='fr'?'Supprimer cette réponse ?':'Delete this response?')) return;
  await sb.from('survey_responses').delete().eq('id',id);
  allData = allData.filter(r=>r.id!==id);
  updateMetrics(); renderList();
}

function prefill(i){
  const r = allData[i];
  document.getElementById('p-name').value = r.contact_name||'';
  document.getElementById('p-biz').value = r.business_name||'';
  const feats=[];
  const L = T[LANG];
  if(r.feat_chatbot==='Must have') feats.push(LANG==='fr'?'Chatbot IA (réponses 24/7)':'AI Chatbot (24/7 responses)');
  if(r.feat_quote==='Must have') feats.push(LANG==='fr'?'Formulaire devis instantané':'Instant quote form');
  if(r.feat_portal==='Must have') feats.push(LANG==='fr'?'Portail client':'Client portal');
  if(r.feat_payment==='Must have') feats.push(LANG==='fr'?'Paiement en ligne (Stripe)':'Online payment (Stripe)');
  if(r.feat_automation==='Must have') feats.push(LANG==='fr'?'Emails automatiques post-devis':'Automated follow-up emails');
  if(r.feat_seo==='Must have') feats.push('SEO — GTA');
  if(r.feat_booking==='Must have') feats.push(LANG==='fr'?'Réservation en ligne':'Online booking');
  document.getElementById('p-feats').value = feats.join('\n');
  document.getElementById('p-timeline').value = r.timeline||'';
  showP('propose', document.querySelectorAll('.ni')[2]);
}

function genProposal(){
  const L = T[LANG];
  const name = document.getElementById('p-name').value||'[Client]';
  const biz  = document.getElementById('p-biz').value||'[Business]';
  const pkg  = document.getElementById('p-pkg').value;
  const price = document.getElementById('p-price').value;
  const feats = document.getElementById('p-feats').value.split('\n').filter(Boolean);
  const timeline = document.getElementById('p-timeline').value||'2–4 sem.';
  const monthly = document.getElementById('p-monthly').value;
  const note = document.getElementById('p-note').value;
  const pkgMap = {
    essential:{n:LANG==='fr'?'Essentiel':'Essential',p:LANG==='fr'?'2 500 $':'$2,500'},
    growth:{n:LANG==='fr'?'Croissance':'Growth',p:LANG==='fr'?'3 900 $':'$3,900'},
    full:{n:LANG==='fr'?'Complet':'Full Suite',p:LANG==='fr'?'6 200 $':'$6,200'},
    custom:{n:LANG==='fr'?'Personnalisé':'Custom',p:price||'TBD'}
  };
  const p = pkgMap[pkg];
  const today = new Date().toLocaleDateString(LANG==='fr'?'fr-CA':'en-CA',{year:'numeric',month:'long',day:'numeric'});
  const sep = '──────────────────────────────';
  const text = LANG==='fr'
    ? `${L.proposal_subject} ${biz}\n\n${L.proposal_hi} ${name},\n\n${L.proposal_thanks} ${biz}.\n\n${note?note+'\n\n':''}${sep}\nPROPOSITION — ${today}\nClient : ${name} / ${biz}\n${L.proposal_pkg} : ${p.n}\n${L.proposal_invest} : ${p.n === 'Personnalisé' ? price||'À définir' : p.p}${monthly?'\n'+L.proposal_monthly_opt+' : '+monthly:''}\n${L.proposal_delay} : ${timeline}\n\n${L.proposal_features} :\n${feats.map(f=>'  ✓ '+f).join('\n')}\n  ✓ ${L.proposal_support}\n  ✓ ${L.proposal_revision}\n  ✓ ${L.proposal_ownership}\n${sep}\n\n${L.proposal_why} :\n${feats.length?'Vos priorités ('+feats.slice(0,2).join(', ')+') sont entièrement couvertes.':''}\n\nNovaris Solution accompagne ${biz} sur le long terme — pas seulement pour ce projet.\n\n${L.proposal_steps} :\n1. ${L.proposal_s1}\n2. ${L.proposal_s2}\n3. ${L.proposal_s3}\n\n${L.proposal_closing}\n\nPatrick Essono\n${L.proposal_title}\nNovaris Solution Inc.\np_essono@hotmail.com`
    : `${L.proposal_subject} ${biz}\n\nHi ${name},\n\n${L.proposal_thanks} ${biz}.\n\n${note?note+'\n\n':''}${sep}\nPROPOSAL — ${today}\nClient: ${name} / ${biz}\n${L.proposal_pkg}: ${p.n}\n${L.proposal_invest}: ${p.p}${monthly?'\n'+L.proposal_monthly_opt+': '+monthly:''}\n${L.proposal_delay}: ${timeline}\n\n${L.proposal_features}:\n${feats.map(f=>'  ✓ '+f).join('\n')}\n  ✓ ${L.proposal_support}\n  ✓ ${L.proposal_revision}\n  ✓ ${L.proposal_ownership}\n${sep}\n\n${L.proposal_why}:\n${feats.length?'Your priorities ('+feats.slice(0,2).join(', ')+') are fully covered.':''}\n\nNovaris Solution is your long-term partner — not just for this project.\n\n${L.proposal_steps}:\n1. ${L.proposal_s1}\n2. ${L.proposal_s2}\n3. ${L.proposal_s3}\n\n${L.proposal_closing}\n\nPatrick Essono\n${L.proposal_title}\nNovaris Solution Inc.\np_essono@hotmail.com`;
  document.getElementById('prop-out').textContent = text;
}

function copyProp(){
  const txt = document.getElementById('prop-out').textContent;
  navigator.clipboard.writeText(txt).then(()=>showToast(LANG==='fr'?'Copié dans le presse-papier !':'Copied to clipboard!', 2500));
}

function renderPipeline(){
  const L = T[LANG];
  ['new','proposal','followup','won'].forEach(stage=>{
    const col = document.getElementById('pipe-'+stage);
    const sMap = {new:'new',proposal:'proposal_sent',followup:'follow_up',won:'won'};
    const items = allData.filter(r=>(r.status||'new')===sMap[stage]);
    col.innerHTML = items.length
      ? items.map(r=>`<div class="pipe-card"><div class="pc-name">${r.contact_name||'—'}</div><div class="pc-biz">${r.business_name||'—'}</div><div class="pc-val">~$${(BUDGET_VAL[r.budget]||2500).toLocaleString()}</div></div>`).join('')
      : `<div class="pipe-empty">—</div>`;
  });
}

function renderInsights(){
  const r = allData; if(!r.length) return;
  const L = T[LANG];
  const featKeys=['feat_chatbot','feat_quote','feat_portal','feat_payment','feat_automation','feat_seo','feat_booking'];
  const fc={};
  featKeys.forEach(k=>{fc[k]=r.filter(x=>x[k]==='Must have').length});
  const sf=Object.entries(fc).sort((a,b)=>b[1]-a[1]).filter(([,v])=>v>0);
  const mf=sf[0]?.[1]||1;
  document.getElementById('feat-chart').innerHTML = sf.length
    ? sf.map(([k,v])=>`<div class="bar-item"><div class="bar-lrow"><span class="bl">${L.feat_names[k]}</span><span>${v}/${r.length}</span></div><div class="bar-track"><div class="bar-fill" style="width:${Math.round(v/mf*100)}%;background:var(--brand)"></div></div></div>`).join('')
    : `<div class="empty-state" style="padding:10px;font-size:.78rem">—</div>`;
  const bm={};r.forEach(x=>{if(x.budget)bm[x.budget]=(bm[x.budget]||0)+1});
  const sb2=Object.entries(bm).sort((a,b)=>b[1]-a[1]);
  const mb=sb2[0]?.[1]||1;
  document.getElementById('budget-chart').innerHTML=sb2.map(([k,v])=>`<div class="bar-item"><div class="bar-lrow"><span class="bl">${k}</span><span>${v}</span></div><div class="bar-track"><div class="bar-fill" style="width:${Math.round(v/mb*100)}%;background:var(--blue)"></div></div></div>`).join('');
  const sources=r.flatMap(x=>x.lead_source?x.lead_source.split(', '):[]).filter(Boolean);
  const sm={};sources.forEach(s=>{sm[s]=(sm[s]||0)+1});
  const ss2=Object.entries(sm).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const ms=ss2[0]?.[1]||1;
  document.getElementById('source-chart').innerHTML=ss2.map(([k,v])=>`<div class="bar-item"><div class="bar-lrow"><span class="bl">${k}</span><span>${v}</span></div><div class="bar-track"><div class="bar-fill" style="width:${Math.round(v/ms*100)}%;background:var(--amber)"></div></div></div>`).join('');
  const pains=r.flatMap(x=>x.manual_task?x.manual_task.split(', '):[]).filter(Boolean);
  const pm={};pains.forEach(p=>{pm[p]=(pm[p]||0)+1});
  const sp2=Object.entries(pm).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const mp=sp2[0]?.[1]||1;
  document.getElementById('pain-chart').innerHTML=sp2.map(([k,v])=>`<div class="bar-item"><div class="bar-lrow"><span class="bl">${k}</span><span>${v}</span></div><div class="bar-track"><div class="bar-fill" style="width:${Math.round(v/mp*100)}%;background:var(--red)"></div></div></div>`).join('');
}

function showP(id, el){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  el.classList.add('active');
  document.getElementById('panel-title').textContent = T[LANG].panels[id];
  document.getElementById('panel-sub').textContent = id==='reponses'?(LANG==='fr'?'Toutes les soumissions':'All submissions'):'Novaris Solution Inc.';
  if(id==='insights'){renderInsights();}
  if(id==='pipeline'){renderPipeline();}
  if(id==='factures'){renderFinMetrics();renderInvoicesList();}
  if(id==='survey'){renderSurveyBuilder();}
}
function showInvTab(id){
  document.getElementById('it-new').classList.toggle('active', id==='new');
  document.getElementById('it-list').classList.toggle('active', id==='list');
  document.getElementById('inv-new').classList.toggle('active', id==='new');
  document.getElementById('inv-list').classList.toggle('active', id==='list');
  if(id==='list') renderInvoicesList();
}

