<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Novaris Solution — Dashboard Clients</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --brand:#6C3FC5;--brand-dark:#5530A3;--brand-dim:rgba(108,63,197,0.10);
  --green:#22C55E;--green-dim:rgba(34,197,94,0.10);
  --blue:#3B82F6;--blue-dim:rgba(59,130,246,0.10);
  --amber:#F59E0B;--red:#EF4444;
  --navy:#0F172A;--navy-mid:#1E293B;
  --white:#FFFFFF;--bg:#F8FAFC;--card:#FFFFFF;
  --text:#0F172A;--muted:#64748B;--border:#E2E8F0;
  --sidebar:240px;--radius:12px;
  --shadow:0 1px 3px rgba(0,0,0,0.06),0 4px 16px rgba(0,0,0,0.04);
}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh;font-size:14px}

/* SIDEBAR */
.sidebar{width:var(--sidebar);background:var(--navy);position:fixed;top:0;bottom:0;left:0;z-index:200;display:flex;flex-direction:column}
.sb-logo{padding:20px 20px 16px;border-bottom:1px solid rgba(255,255,255,0.07);display:flex;align-items:center;gap:10px}
.sb-logo-icon{width:32px;height:32px;background:var(--brand);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sb-logo-icon svg{color:#fff;width:18px;height:18px}
.sb-logo-text h2{font-size:.82rem;font-weight:700;color:#fff;line-height:1.2}
.sb-logo-text span{font-size:.65rem;color:rgba(255,255,255,0.35);display:block;margin-top:1px}
.sb-section{padding:14px 12px 6px;font-size:.62rem;font-weight:700;color:rgba(255,255,255,0.25);text-transform:uppercase;letter-spacing:.1em}
.sb-nav{flex:1;padding:0 8px;overflow-y:auto}
.ni{display:flex;align-items:center;gap:9px;padding:8px 12px;color:rgba(255,255,255,0.55);font-size:.8rem;font-weight:500;cursor:pointer;border-radius:8px;transition:all .18s;margin-bottom:1px;border:none;background:none;width:100%;text-align:left}
.ni:hover{color:#fff;background:rgba(255,255,255,0.06)}
.ni.active{color:#fff;background:rgba(108,63,197,0.35);font-weight:600}
.ni svg{width:15px;height:15px;flex-shrink:0}
.ni-badge{margin-left:auto;background:var(--brand);color:#fff;font-size:.6rem;font-weight:700;padding:1px 6px;border-radius:100px;min-width:18px;text-align:center}
.live-pulse{width:7px;height:7px;background:#22C55E;border-radius:50%;margin-left:auto;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
.sb-footer{padding:14px 16px;border-top:1px solid rgba(255,255,255,0.07)}
.sb-footer .version{font-size:.65rem;color:rgba(255,255,255,0.25);margin-bottom:6px}
.sb-footer .user{display:flex;align-items:center;gap:8px}
.sb-avatar{width:28px;height:28px;background:var(--brand);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;color:#fff;flex-shrink:0}
.sb-user-info strong{display:block;font-size:.75rem;font-weight:600;color:#fff}
.sb-user-info span{font-size:.65rem;color:rgba(255,255,255,0.35)}
.lang-toggle{display:flex;gap:4px;margin-top:8px}
.lt-btn{flex:1;padding:4px;border:1px solid rgba(255,255,255,0.15);border-radius:5px;background:none;color:rgba(255,255,255,0.4);font-size:.68rem;font-weight:600;cursor:pointer;transition:all .18s;font-family:'Inter',sans-serif}
.lt-btn.active{background:var(--brand);border-color:var(--brand);color:#fff}

/* MAIN */
.main{margin-left:var(--sidebar);flex:1;display:flex;flex-direction:column;min-height:100vh}
.topbar{background:var(--white);border-bottom:1px solid var(--border);padding:11px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.topbar-left h1{font-size:.9rem;font-weight:600;color:var(--navy)}
.topbar-left p{font-size:.72rem;color:var(--muted);margin-top:1px}
.topbar-right{display:flex;gap:8px;align-items:center}
.status-pill{display:inline-flex;align-items:center;gap:5px;font-size:.72rem;font-weight:600;padding:4px 10px;border-radius:100px}
.sp-live{background:var(--green-dim);color:#15803D}
.sp-warn{background:rgba(245,158,11,0.12);color:#92400E}
.btn{border:none;padding:6px 14px;border-radius:7px;font-family:'Inter',sans-serif;font-size:.77rem;font-weight:600;cursor:pointer;transition:all .18s;display:inline-flex;align-items:center;gap:5px}
.btn svg{width:13px;height:13px}
.btn-brand{background:var(--brand);color:#fff}.btn-brand:hover{background:var(--brand-dark)}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--navy)}.btn-outline:hover{background:var(--bg)}
.btn-danger{background:transparent;border:1px solid #FECACA;color:var(--red)}.btn-danger:hover{background:#FEF2F2}
.btn-sm{padding:4px 10px;font-size:.72rem}

.content{padding:20px 24px;flex:1}
.panel{display:none}.panel.active{display:block}

/* METRICS */
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
.mc{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;transition:box-shadow .2s}
.mc:hover{box-shadow:var(--shadow)}
.mc-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:10px}
.mc-icon svg{width:16px;height:16px}
.mc .lbl{font-size:.68rem;color:var(--muted);font-weight:500;margin-bottom:2px}
.mc .val{font-size:1.5rem;font-weight:700;color:var(--navy);line-height:1}
.mc .sub{font-size:.67rem;color:var(--muted);margin-top:3px}
.mc.brand .mc-icon{background:var(--brand-dim)}.mc.brand .mc-icon svg{color:var(--brand)}.mc.brand .val{color:var(--brand)}
.mc.green .mc-icon{background:var(--green-dim)}.mc.green .mc-icon svg{color:#15803D}.mc.green .val{color:#15803D}
.mc.blue .mc-icon{background:var(--blue-dim)}.mc.blue .mc-icon svg{color:#1D4ED8}.mc.blue .val{color:#1D4ED8}
.mc.amber .mc-icon{background:rgba(245,158,11,0.1)}.mc.amber .mc-icon svg{color:#92400E}.mc.amber .val{color:#92400E}

/* CARDS */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:14px}
.card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.card-title{font-size:.85rem;font-weight:600;color:var(--navy)}
.card-sub{font-size:.72rem;color:var(--muted);margin-top:1px}
.empty-state{text-align:center;padding:36px 20px;color:var(--muted);font-size:.83rem;line-height:1.6}

/* NOTIF */
.notif-toast{position:fixed;bottom:20px;right:20px;z-index:999;background:var(--navy-mid);color:#fff;padding:12px 16px;border-radius:12px;font-size:.8rem;display:flex;align-items:center;gap:10px;box-shadow:0 8px 32px rgba(0,0,0,0.25);transform:translateY(80px);opacity:0;transition:all .3s;max-width:340px;border-left:3px solid var(--brand)}
.notif-toast.show{transform:translateY(0);opacity:1}
.notif-toast .ndot{width:8px;height:8px;background:#22C55E;border-radius:50%;flex-shrink:0;animation:pulse 2s infinite}

/* RESPONSE LIST */
.resp-list{display:flex;flex-direction:column;gap:6px}
.rrow{border:1px solid var(--border);border-radius:10px;overflow:hidden;transition:box-shadow .18s;background:var(--card)}
.rrow:hover{box-shadow:var(--shadow)}
.rrow.expanded .rbody{display:block}
.rhead{display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;padding:10px 14px;cursor:pointer;background:var(--bg);border-bottom:1px solid transparent}
.rrow.expanded .rhead{border-bottom-color:var(--border);background:var(--white)}
.ravatar{width:34px;height:34px;border-radius:50%;background:var(--brand-dim);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:var(--brand);flex-shrink:0}
.rname{font-size:.83rem;font-weight:600;color:var(--navy)}
.rbiz{font-size:.72rem;color:var(--muted);margin-top:1px}
.rmeta{display:flex;align-items:center;gap:6px;flex-wrap:wrap;justify-content:flex-end}
.rdate{font-size:.68rem;color:var(--muted)}
.badge{display:inline-flex;align-items:center;gap:3px;font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:100px;white-space:nowrap}
.b-new{background:rgba(34,197,94,0.12);color:#15803D}
.b-seen{background:var(--blue-dim);color:#1D4ED8}
.b-proposal{background:var(--brand-dim);color:var(--brand-dark)}
.b-won{background:rgba(34,197,94,0.2);color:#14532D}
.b-score-hi{background:rgba(34,197,94,0.12);color:#15803D}
.b-score-mid{background:rgba(245,158,11,0.12);color:#92400E}
.b-score-lo{background:rgba(239,68,68,0.1);color:#B91C1C}
.rbody{display:none;padding:14px}

/* DETAIL SECTIONS */
.det-section{margin-bottom:14px}
.det-label{font-size:.65rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px;padding-bottom:5px;border-bottom:1px solid var(--border)}
.det-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.det-item .dl{font-size:.65rem;color:var(--muted);font-weight:600;margin-bottom:2px}
.det-item .dv{font-size:.8rem;color:var(--text)}

/* TRANSLATION BOX */
.tbox{background:linear-gradient(135deg,var(--brand-dim),var(--blue-dim));border:1px solid rgba(108,63,197,0.2);border-radius:10px;padding:12px 14px;margin-bottom:12px}
.tbox-head{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.tbox-badge{background:var(--brand);color:#fff;font-size:.6rem;font-weight:700;padding:2px 7px;border-radius:4px;letter-spacing:.04em}
.tbox-label{font-size:.68rem;font-weight:700;color:var(--brand-dark)}
.tbox-free{background:#DCFCE7;color:#15803D;font-size:.6rem;font-weight:700;padding:2px 6px;border-radius:4px}
.tbox-content{font-size:.8rem;color:var(--text);line-height:1.65}
.tbox-section{margin-bottom:8px}
.tbox-section:last-child{margin-bottom:0}
.tbox-section .ts-label{font-size:.63rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px}
.tbox-section .ts-val{font-size:.8rem;color:var(--text);line-height:1.55}
.tloading{font-size:.78rem;color:var(--muted);font-style:italic}

/* FEAT TAGS */
.feat-wrap{display:flex;flex-wrap:wrap;gap:4px;margin-top:4px}
.ft{font-size:.63rem;font-weight:700;padding:2px 7px;border-radius:4px}
.ft-must{background:rgba(34,197,94,0.12);color:#15803D}
.ft-nice{background:var(--blue-dim);color:#1D4ED8}
.ft-no{background:rgba(239,68,68,0.08);color:#B91C1C}

/* SCORE BAR */
.score-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.score-track{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.score-fill{height:100%;border-radius:3px;transition:width .5s ease}
.score-label{font-size:.72rem;font-weight:600;min-width:48px;text-align:right}

/* ACTIONS */
.act-row{display:flex;gap:6px;flex-wrap:wrap;padding-top:10px;border-top:1px solid var(--border);margin-top:12px}
.status-sel{font-size:.72rem;padding:6px 10px;border:1px solid var(--border);border-radius:6px;background:var(--white);color:var(--text);font-family:'Inter',sans-serif;cursor:pointer}

/* PROPOSAL */
.proposal-wrap{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.pf label{display:block;font-size:.72rem;font-weight:600;color:var(--navy);margin-bottom:3px;margin-top:10px}
.pf label:first-child{margin-top:0}
.pf input,.pf select,.pf textarea{width:100%;padding:7px 10px;border:1px solid var(--border);border-radius:7px;font-family:'Inter',sans-serif;font-size:.8rem;color:var(--text);outline:none;transition:border-color .18s;background:var(--white)}
.pf input:focus,.pf select:focus,.pf textarea:focus{border-color:var(--brand)}
.pf textarea{min-height:68px;resize:vertical;line-height:1.55}
.prop-out{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px;font-size:.78rem;line-height:1.8;white-space:pre-wrap;font-family:'Inter',sans-serif;color:var(--text);min-height:200px}

/* INSIGHTS */
.ins-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.ins-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px}
.ins-title{font-size:.68rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px}
.bar-item{margin-bottom:7px}
.bar-lrow{display:flex;justify-content:space-between;font-size:.73rem;margin-bottom:2px;color:var(--muted)}
.bar-lrow .bl{color:var(--text)}
.bar-track{height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.bar-fill{height:100%;border-radius:3px}

/* PIPELINE */
.pipe-board{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.pipe-col-head{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:6px 10px;border-radius:6px;margin-bottom:6px;text-align:center}
.ph-new{background:var(--green-dim);color:#15803D}
.ph-proposal{background:var(--brand-dim);color:var(--brand-dark)}
.ph-followup{background:rgba(245,158,11,0.1);color:#92400E}
.ph-won{background:rgba(34,197,94,0.2);color:#14532D}
.pipe-card{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:9px 11px;margin-bottom:6px}
.pc-name{font-size:.78rem;font-weight:600;color:var(--navy)}
.pc-biz{font-size:.68rem;color:var(--muted);margin-top:1px}
.pc-val{font-size:.73rem;font-weight:600;color:var(--brand);margin-top:4px}
.pipe-empty{font-size:.72rem;color:var(--muted);text-align:center;padding:14px 8px;border:1px dashed var(--border);border-radius:8px}

/* LOGIN GATE */
.login-wrap{position:fixed;inset:0;background:var(--navy);display:flex;align-items:center;justify-content:center;z-index:1000}
.login-card{background:var(--white);border-radius:16px;padding:32px 30px;width:100%;max-width:360px;box-shadow:0 20px 60px rgba(0,0,0,0.3)}
.login-card h1{font-size:1rem;font-weight:700;color:var(--navy);margin-bottom:2px}
.login-card p{font-size:.78rem;color:var(--muted);margin-bottom:18px}
.login-card label{display:block;font-size:.72rem;font-weight:600;color:var(--navy);margin-bottom:4px;margin-top:12px}
.login-card label:first-of-type{margin-top:0}
.login-card input{width:100%;padding:9px 11px;border:1px solid var(--border);border-radius:8px;font-family:'Inter',sans-serif;font-size:.85rem;outline:none}
.login-card input:focus{border-color:var(--brand)}
.login-err{font-size:.72rem;color:var(--red);margin-top:8px;display:none}
.login-err.show{display:block}
.hidden{display:none !important}

/* FACTURES */
.inv-tabs{display:flex;gap:6px;margin-bottom:14px}
.inv-tab{padding:7px 14px;border-radius:8px;border:1px solid var(--border);background:var(--white);font-size:.78rem;font-weight:600;color:var(--muted);cursor:pointer;font-family:'Inter',sans-serif}
.inv-tab.active{background:var(--brand);border-color:var(--brand);color:#fff}
.inv-subpanel{display:none}.inv-subpanel.active{display:block}
.inv-wrap{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.inv-form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.opt-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:4px}
.chip{font-size:.72rem;padding:5px 10px;border:1px solid var(--border);border-radius:100px;cursor:pointer;background:var(--white);color:var(--text);user-select:none}
.chip.sel{background:var(--brand-dim);border-color:var(--brand);color:var(--brand-dark);font-weight:600}
.inv-num{font-family:monospace;font-size:.95rem;font-weight:700;color:var(--brand);background:var(--brand-dim);padding:6px 10px;border-radius:7px;display:inline-block}
.pay-fields{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px;margin-top:8px}
.calc-row{display:flex;justify-content:space-between;font-size:.8rem;padding:5px 0;border-bottom:1px dashed var(--border)}
.calc-row:last-child{border-bottom:none;font-weight:700;font-size:.88rem;color:var(--navy);padding-top:8px}
.inv-list{display:flex;flex-direction:column;gap:6px}
.inv-row{display:grid;grid-template-columns:auto 1fr auto auto auto;gap:10px;align-items:center;padding:10px 12px;border:1px solid var(--border);border-radius:10px;background:var(--card)}
.inv-row .num{font-family:monospace;font-size:.75rem;color:var(--brand);font-weight:700}
.inv-row .biz{font-size:.82rem;font-weight:600;color:var(--navy)}
.inv-row .sub{font-size:.7rem;color:var(--muted)}
.inv-row .amt{font-size:.85rem;font-weight:700;color:var(--navy);text-align:right}
.b-draft{background:var(--border);color:var(--muted)}
.b-sent{background:var(--blue-dim);color:#1D4ED8}
.b-paid{background:var(--green-dim);color:#15803D}
.b-overdue{background:rgba(239,68,68,0.1);color:#B91C1C}
.b-cancelled{background:rgba(100,116,139,0.12);color:var(--muted)}
.pdf-preview-frame{width:100%;height:520px;border:1px solid var(--border);border-radius:10px;background:var(--bg)}

/* SURVEY BUILDER */
.sv-step-card{border:1px solid var(--border);border-radius:10px;margin-bottom:10px;background:var(--card)}
.sv-step-head{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:var(--bg);border-bottom:1px solid var(--border);border-radius:10px 10px 0 0;font-size:.78rem;font-weight:700;color:var(--navy)}
.sv-field-row{display:flex;align-items:center;justify-content:space-between;padding:9px 14px;border-bottom:1px solid var(--border);gap:10px}
.sv-field-row:last-child{border-bottom:none}
.sv-field-info{font-size:.78rem;color:var(--text)}
.sv-field-info .k{font-family:monospace;font-size:.68rem;color:var(--muted);margin-left:6px}
.sv-field-actions{display:flex;gap:4px;flex-shrink:0}
.sv-field-actions button{background:none;border:1px solid var(--border);border-radius:6px;padding:4px 7px;cursor:pointer;color:var(--muted)}
.sv-field-actions button:hover{color:var(--brand);border-color:var(--brand)}
.sv-editor{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;position:sticky;top:70px}
.opt-editor-row{display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:6px;margin-bottom:6px;align-items:center}
.opt-editor-row input{padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:.75rem;font-family:'Inter',sans-serif}
.toggle-row{display:flex;align-items:center;gap:8px;margin-top:10px}
.toggle-row label{font-size:.78rem;color:var(--navy);font-weight:500}
.sv-inactive{opacity:.45}

@media(max-width:960px){
  .sidebar{width:56px}.sb-logo-text,.sb-section,.sb-user-info,.lang-toggle,.ni span,.ni-badge,.live-pulse{display:none}
  .main{margin-left:56px}.metrics{grid-template-columns:1fr 1fr}
  .proposal-wrap{grid-template-columns:1fr}.ins-grid{grid-template-columns:1fr}
  .pipe-board{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>

<!-- ── CONFIG ── -->
<script>
const SUPABASE_URL = 'https://aoeonvhohwgcjnvswlbt.supabase.co';
const SUPABASE_ANON_KEY = 'sb_publishable_259KgrJGFJIQnN4edkYGhw_e4gdyqq2';
// Traduction : MyMemory API — 100% gratuit, 5000 mots/jour, aucun compte requis
// URL de l'Edge Function Supabase qui envoie les factures via Resend (voir README)
const SEND_INVOICE_URL = SUPABASE_URL + '/functions/v1/send-invoice';
</script>

<!-- LOGIN GATE (Supabase Auth) -->
<div class="login-wrap" id="login-wrap">
  <div class="login-card">
    <h1 id="login-title">Novaris Solution</h1>
    <p id="login-sub">Connexion au dashboard client</p>
    <label id="login-lbl-email">Courriel</label>
    <input type="email" id="login-email" placeholder="patrick@novaris-solution.com">
    <label id="login-lbl-pass">Mot de passe</label>
    <input type="password" id="login-pass" placeholder="••••••••">
    <div class="login-err" id="login-err">Identifiants invalides.</div>
    <button class="btn btn-brand" style="width:100%;justify-content:center;margin-top:16px;padding:10px" onclick="doLogin()">
      <span id="login-btn">Se connecter</span>
    </button>
    <div style="text-align:center;margin-top:14px">
      <a href="#" onclick="skipLogin();return false" style="font-size:.72rem;color:var(--muted);text-decoration:underline" id="login-skip">Continuer sans connexion pour l'instant (temporaire)</a>
    </div>
  </div>
</div>

<div id="app-root" class="hidden">
<!-- SIDEBAR -->
<nav class="sidebar">
  <div class="sb-logo">
    <div class="sb-logo-icon">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
    </div>
    <div class="sb-logo-text">
      <h2>Novaris</h2>
      <span>Solution Inc.</span>
    </div>
  </div>

  <div class="sb-nav">
    <div class="sb-section">Clients</div>
    <button class="ni active" onclick="showP('reponses',this)">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      <span id="t-responses">Réponses</span>
      <span class="ni-badge" id="nb-new">0</span>
    </button>
    <button class="ni" onclick="showP('pipeline',this)">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      <span id="t-pipeline">Pipeline</span>
    </button>
    <div class="sb-section">Outils</div>
    <button class="ni" onclick="showP('propose',this)">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      <span id="t-devis">Générer Devis</span>
    </button>
    <button class="ni" onclick="showP('insights',this)">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
      <span id="t-insights">Insights</span>
    </button>
    <button class="ni" onclick="showP('factures',this)">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l2 2 4-4m4.618-3.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      <span id="t-factures">Factures</span>
    </button>
    <div class="sb-section" id="sb-admin">Admin</div>
    <button class="ni" onclick="showP('survey',this)">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      <span id="t-survey">Survey</span>
    </button>
  </div>

  <div class="sb-footer">
    <div class="version">v1.0 · Novaris Solution</div>
    <div class="user">
      <div class="sb-avatar">PE</div>
      <div class="sb-user-info">
        <strong>Patrick Essono</strong>
        <span>Directeur Technique</span>
      </div>
    </div>
    <!-- Toggle FR / EN -->
    <div class="lang-toggle" style="margin-top:8px">
      <button class="lt-btn active" id="btn-fr" onclick="setLang('fr')">FR</button>
      <button class="lt-btn" id="btn-en" onclick="setLang('en')">EN</button>
    </div>
  </div>
</nav>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <h1 id="panel-title">Réponses Survey</h1>
      <p id="panel-sub">Shining Legacy — Danielle</p>
    </div>
    <div class="topbar-right">
      <span class="status-pill sp-live" id="live-badge">● Temps réel</span>
      <span class="badge b-seen" id="count-badge">0</span>
      <button class="btn btn-outline btn-sm" onclick="loadAll()">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        <span id="t-refresh">Actualiser</span>
      </button>
    </div>
  </div>

  <div class="content">

    <!-- MÉTRIQUES -->
    <div class="metrics">
      <div class="mc brand">
        <div class="mc-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
        <div class="lbl" id="m-lbl-total">Total réponses</div><div class="val" id="m-total">0</div><div class="sub" id="m-sub-total">Tous les clients</div>
      </div>
      <div class="mc green">
        <div class="mc-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg></div>
        <div class="lbl" id="m-lbl-new">Nouvelles</div><div class="val" id="m-new">0</div><div class="sub" id="m-sub-new">À consulter</div>
      </div>
      <div class="mc blue">
        <div class="mc-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
        <div class="lbl" id="m-lbl-pipe">Pipeline estimé</div><div class="val" id="m-pipe">$0</div><div class="sub" id="m-sub-pipe">Valeur totale</div>
      </div>
      <div class="mc amber">
        <div class="mc-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg></div>
        <div class="lbl" id="m-lbl-budget">Budget populaire</div><div class="val" id="m-budget">—</div><div class="sub" id="m-sub-budget">Le plus sélectionné</div>
      </div>
    </div>

    <!-- RÉPONSES -->
    <div class="panel active" id="panel-reponses">
      <div class="card">
        <div class="card-head">
          <div><div class="card-title" id="ct-responses">Soumissions reçues</div><div class="card-sub" id="cs-responses">Cliquez sur une réponse pour voir les détails et la traduction</div></div>
          <select id="filter-status" onchange="renderList()" style="font-size:.75rem;padding:5px 10px;border:1px solid var(--border);border-radius:6px;background:var(--white);color:var(--text)">
            <option value="" id="f-all">Tous</option>
            <option value="new" id="f-new">Nouveaux</option>
            <option value="reviewed" id="f-rev">Consultés</option>
            <option value="proposal_sent" id="f-prop">Devis envoyé</option>
            <option value="won" id="f-won">Signés</option>
          </select>
        </div>
        <div class="resp-list" id="resp-list">
          <div class="empty-state" id="empty-msg">En attente des premières réponses de Danielle…</div>
        </div>
      </div>
    </div>

    <!-- PIPELINE -->
    <div class="panel" id="panel-pipeline">
      <div class="pipe-board" id="pipe-board">
        <div><div class="pipe-col-head ph-new" id="ph-new">Nouveau lead</div><div id="pipe-new"></div></div>
        <div><div class="pipe-col-head ph-proposal" id="ph-proposal">Devis envoyé</div><div id="pipe-proposal"></div></div>
        <div><div class="pipe-col-head ph-followup" id="ph-followup">Suivi requis</div><div id="pipe-followup"></div></div>
        <div><div class="pipe-col-head ph-won" id="ph-won">Signé</div><div id="pipe-won"></div></div>
      </div>
    </div>

    <!-- DEVIS -->
    <div class="panel" id="panel-propose">
      <div class="proposal-wrap">
        <div class="card">
          <div class="card-title" id="ct-devis" style="margin-bottom:12px">Paramètres du devis</div>
          <div class="pf">
            <label id="pl-name">Nom du client</label><input type="text" id="p-name" placeholder="ex. Danielle">
            <label id="pl-biz">Entreprise</label><input type="text" id="p-biz" placeholder="ex. Shining Legacy Cleaning Inc">
            <label id="pl-pkg">Forfait</label>
            <select id="p-pkg">
              <option value="essential" id="pkg-e">Essentiel — 2 500 $ (site + chatbot + SEO)</option>
              <option value="growth" id="pkg-g">Croissance — 3 900 $ (+ automation + booking)</option>
              <option value="full" id="pkg-f">Complet — 6 200 $ (+ dashboard + portail + paiements)</option>
              <option value="custom" id="pkg-c">Personnalisé</option>
            </select>
            <label id="pl-price">Prix personnalisé (optionnel)</label><input type="text" id="p-price" placeholder="ex. 4 200 $">
            <label id="pl-feats">Fonctionnalités incluses (une par ligne)</label>
            <textarea id="p-feats" placeholder="Chatbot IA (24/7)&#10;Formulaire devis instantané&#10;Portail client&#10;Paiement en ligne (Stripe)&#10;SEO — GTA"></textarea>
            <label id="pl-timeline">Délai de livraison</label><input type="text" id="p-timeline" placeholder="ex. 2–3 semaines">
            <label id="pl-monthly">Option mensuelle</label><input type="text" id="p-monthly" placeholder="ex. 250 $/mois après lancement">
            <label id="pl-note">Note personnelle</label>
            <textarea id="p-note" placeholder="Référence à quelque chose mentionné dans le survey…"></textarea>
            <button class="btn btn-brand" style="margin-top:12px;width:100%;padding:9px;justify-content:center" onclick="genProposal()">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              <span id="btn-gen">Générer le devis</span>
            </button>
          </div>
        </div>
        <div class="card">
          <div class="card-title" id="ct-preview" style="margin-bottom:10px">Aperçu du devis</div>
          <div class="prop-out" id="prop-out" id="prop-placeholder">Remplis les paramètres et clique "Générer".</div>
          <button class="btn btn-outline" style="margin-top:8px;width:100%;justify-content:center" onclick="copyProp()">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            <span id="btn-copy">Copier dans le presse-papier</span>
          </button>
        </div>
      </div>
    </div>

    <!-- INSIGHTS -->
    <div class="panel" id="panel-insights">
      <div class="ins-grid">
        <div class="ins-card"><div class="ins-title" id="ins-t1">Fonctionnalités "must have"</div><div id="feat-chart"><div class="empty-state" style="padding:14px;font-size:.78rem">Aucune donnée</div></div></div>
        <div class="ins-card"><div class="ins-title" id="ins-t2">Distribution des budgets</div><div id="budget-chart"><div class="empty-state" style="padding:14px;font-size:.78rem">Aucune donnée</div></div></div>
        <div class="ins-card"><div class="ins-title" id="ins-t3">Sources de leads actuelles</div><div id="source-chart"><div class="empty-state" style="padding:14px;font-size:.78rem">Aucune donnée</div></div></div>
        <div class="ins-card"><div class="ins-title" id="ins-t4">Pain points opérationnels</div><div id="pain-chart"><div class="empty-state" style="padding:14px;font-size:.78rem">Aucune donnée</div></div></div>
      </div>
    </div>

    <!-- FACTURES -->
    <div class="panel" id="panel-factures">
      <div class="metrics" id="fin-metrics">
        <div class="mc brand"><div class="lbl" id="fm-lbl-1">Montant conclu</div><div class="val" id="fm-1">0 $</div><div class="sub" id="fm-sub-1">Total facturé</div></div>
        <div class="mc green"><div class="lbl" id="fm-lbl-2">Mensualités payées</div><div class="val" id="fm-2">0 $</div><div class="sub" id="fm-sub-2">Encaissé</div></div>
        <div class="mc amber"><div class="lbl" id="fm-lbl-3">Mensualités à payer</div><div class="val" id="fm-3">0 $</div><div class="sub" id="fm-sub-3">En attente</div></div>
        <div class="mc blue"><div class="lbl" id="fm-lbl-4">Montant net</div><div class="val" id="fm-4">0 $</div><div class="sub" id="fm-sub-4">Après impôts estimés</div></div>
      </div>
      <div class="card" style="margin-bottom:14px">
        <div class="calc-row" style="border:none;font-size:.78rem;color:var(--muted)">
          <span id="fm-tax-lbl">Impôts estimés à provisionner (sur montant encaissé)</span>
          <span id="fm-tax-val" style="font-weight:700;color:var(--navy)">0 $</span>
        </div>
        <div style="display:flex;gap:8px;align-items:center;margin-top:8px">
          <label style="font-size:.75rem;color:var(--navy);font-weight:600" id="fm-rate-lbl">Taux de taxe / provision (%)</label>
          <input type="number" id="tax-rate-input" step="0.01" style="width:90px;padding:5px 8px;border:1px solid var(--border);border-radius:6px;font-family:'Inter',sans-serif" onchange="saveTaxRate(this.value)">
        </div>
      </div>

      <div class="inv-tabs">
        <button class="inv-tab active" id="it-new" onclick="showInvTab('new')">Nouvelle facture</button>
        <button class="inv-tab" id="it-list" onclick="showInvTab('list')">Historique</button>
      </div>

      <div class="inv-subpanel active" id="inv-new">
        <div class="inv-wrap">
          <div class="card">
            <div class="card-title" style="margin-bottom:12px" id="inv-form-title">Détails de la facture</div>
            <div class="pf">
              <label id="il-num">Numéro de facture</label>
              <div><span class="inv-num" id="inv-number-disp">NOV-2026-00000</span> <button class="btn btn-outline btn-sm" onclick="genInvoiceNumber()" id="il-regen">Régénérer</button></div>

              <label id="il-resp" style="margin-top:12px">Lier à une réponse survey (optionnel)</label>
              <select id="inv-response" onchange="prefillFromResponse()"><option value="" id="il-resp-none">— Sélection manuelle —</option></select>

              <div class="inv-form-row">
                <div><label id="il-name">Nom du client</label><input type="text" id="inv-name"></div>
                <div><label id="il-biz">Compagnie du client</label><input type="text" id="inv-biz"></div>
              </div>
              <label id="il-email">Courriel du client</label><input type="email" id="inv-email" placeholder="client@exemple.com">

              <label id="il-pkg" style="margin-top:12px">Forfait</label>
              <select id="inv-pkg" onchange="onPkgChange()">
                <option value="essential" id="ipkg-e">Essentiel — 2 500 $</option>
                <option value="growth" id="ipkg-g">Croissance — 3 900 $</option>
                <option value="full" id="ipkg-f">Complet — 6 200 $</option>
                <option value="custom" id="ipkg-c">Personnalisé</option>
              </select>

              <label id="il-feats">Options incluses (cliquez pour sélectionner)</label>
              <div class="opt-chips" id="inv-feat-chips"></div>

              <div class="inv-form-row" style="margin-top:10px">
                <div><label id="il-amount">Montant (avant taxes) $</label><input type="number" step="0.01" id="inv-amount" oninput="recalcInvoice()"></div>
                <div><label id="il-freq">Fréquence</label>
                  <select id="inv-freq" onchange="onFreqChange()">
                    <option value="unique" id="ifreq-u">Paiement unique</option>
                    <option value="mensuel" id="ifreq-m">Mensuel</option>
                    <option value="hebdomadaire" id="ifreq-h">Hebdomadaire</option>
                    <option value="annuel" id="ifreq-a">Annuel</option>
                  </select>
                </div>
              </div>

              <div class="inv-form-row" id="inv-installments-wrap" style="display:none">
                <div><label id="il-count">Nombre de versements</label><input type="number" min="1" id="inv-count" value="1" oninput="recalcInvoice()"></div>
                <div><label id="il-start">Date du 1er versement</label><input type="date" id="inv-start"></div>
              </div>
              <div class="inv-form-row" id="inv-due-wrap">
                <div><label id="il-due">Date d'échéance</label><input type="date" id="inv-due"></div>
                <div><label id="il-lang">Langue du document</label>
                  <select id="inv-lang"><option value="fr" id="ilang-fr">Français</option><option value="en" id="ilang-en">English</option></select>
                </div>
              </div>

              <label id="il-method" style="margin-top:12px">Type de paiement souhaité</label>
              <select id="inv-method" onchange="onMethodChange()">
                <option value="virement" id="imeth-v">Virement bancaire</option>
                <option value="interac" id="imeth-i">Virement Interac</option>
                <option value="carte" id="imeth-c">Carte de crédit</option>
                <option value="cheque" id="imeth-ch">Chèque</option>
                <option value="autre" id="imeth-a">Autre</option>
              </select>
              <div class="pay-fields">
                <label id="il-details" style="margin-top:0">Coordonnées de paiement (courriel Interac, infos virement, etc.)</label>
                <textarea id="inv-details" class="fld" style="width:100%;min-height:60px;padding:8px;border:1px solid var(--border);border-radius:7px;font-family:'Inter',sans-serif;font-size:.8rem"></textarea>
              </div>

              <div class="toggle-row" style="margin-top:14px;background:var(--brand-dim);padding:10px 12px;border-radius:8px">
                <input type="checkbox" id="inv-contract" onchange="recalcInvoice()">
                <label id="il-contract" style="font-weight:600">Document contractuel (ajoute les clauses et les blocs de signature)</label>
              </div>

              <label id="il-notes" style="margin-top:12px">Notes internes (n'apparaissent pas sur le PDF)</label>
              <textarea id="inv-notes"></textarea>

              <div class="card" style="margin-top:14px;background:var(--bg)">
                <div class="calc-row"><span id="ic-sub">Sous-total</span><span id="ic-sub-val">0,00 $</span></div>
                <div class="calc-row"><span id="ic-tax">Taxes</span><span id="ic-tax-val">0,00 $</span></div>
                <div class="calc-row"><span id="ic-total">Total</span><span id="ic-total-val">0,00 $</span></div>
              </div>

              <div style="display:flex;gap:8px;margin-top:14px">
                <button class="btn btn-outline" style="flex:1;justify-content:center" onclick="previewInvoicePDF()"><span id="ib-preview">Aperçu PDF</span></button>
                <button class="btn btn-outline" style="flex:1;justify-content:center" onclick="downloadInvoicePDF()"><span id="ib-download">Télécharger</span></button>
              </div>
              <div style="display:flex;gap:8px;margin-top:8px">
                <button class="btn btn-outline" style="flex:1;justify-content:center" onclick="generateEmailMessage()"><span id="ib-genmsg">Générer message courriel</span></button>
                <button class="btn btn-brand" style="flex:1;justify-content:center" onclick="saveAndSendInvoice()"><span id="ib-send">Enregistrer + Envoyer (Resend)</span></button>
              </div>
              <div style="font-size:.7rem;color:var(--muted);margin-top:8px" id="ib-hint">« Générer message courriel » fonctionne dès maintenant, sans configuration. « Enregistrer + Envoyer » nécessite Resend + la base de données (voir README) — à activer plus tard.</div>
            </div>
          </div>
          <div class="card">
            <div class="card-title" style="margin-bottom:10px" id="ct-inv-preview">Aperçu PDF</div>
            <iframe class="pdf-preview-frame" id="inv-pdf-frame"></iframe>
            <div class="card-title" style="margin:16px 0 10px" id="ct-email-msg">Message courriel (à copier-coller manuellement)</div>
            <textarea id="inv-email-text" class="fld" style="width:100%;min-height:180px;padding:10px;border:1px solid var(--border);border-radius:8px;font-family:'Inter',sans-serif;font-size:.8rem" readonly placeholder="Clique sur « Générer message courriel » à gauche."></textarea>
            <button class="btn btn-outline" style="margin-top:8px;width:100%;justify-content:center" onclick="copyEmailMessage()"><span id="ib-copymsg">Copier le message</span></button>
          </div>
        </div>
      </div>

      <div class="inv-subpanel" id="inv-list">
        <div class="card">
          <div class="card-head">
            <div><div class="card-title" id="ct-inv-list">Historique des factures</div></div>
          </div>
          <div class="inv-list" id="invoices-list"><div class="empty-state" id="inv-empty">Aucune facture pour le moment.</div></div>
        </div>
      </div>
    </div>

    <!-- SURVEY BUILDER -->
    <div class="panel" id="panel-survey">
      <div class="inv-wrap">
        <div>
          <div class="card-head" style="margin-bottom:10px">
            <div><div class="card-title" id="sv-title">Étapes du questionnaire</div><div class="card-sub" id="sv-sub">Modifiez, réordonnez ou ajoutez des questions — le survey public se met à jour instantanément.</div></div>
            <button class="btn btn-brand btn-sm" onclick="addNewStep()"><span id="sv-add-step">+ Nouvelle étape</span></button>
          </div>
          <div id="sv-steps-list"></div>
        </div>
        <div class="sv-editor" id="sv-editor">
          <div class="empty-state" id="sv-editor-empty">Sélectionnez une question à gauche pour la modifier, ou créez-en une nouvelle.</div>
        </div>
      </div>
    </div>
  </div>
</div>

</div><!-- /app-root -->

<!-- TOAST NOTIFICATION -->
<div class="notif-toast" id="toast">
  <div class="ndot"></div>
  <span id="toast-msg"></span>
</div>

